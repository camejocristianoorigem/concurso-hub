generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Concurso {
  id                  String   @id @default(cuid())
  titulo              String
  orgao               String
  banca               String
  estado              String
  area                String
  cargo               String
  salario             Float
  vagas               Int
  nivel               String
  status              String
  dataPublicacao      DateTime
  dataInscricaoInicio DateTime
  dataInscricaoFim    DateTime
  linkEdital          String
  createdAt           DateTime @default(now())
}
